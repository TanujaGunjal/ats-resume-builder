# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (Choose ONE)
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/b2world_ats

# MongoDB Atlas (Recommended):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/b2world_ats?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=b2world_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Admin Default Credentials
ADMIN_EMAIL=admin@b2world.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=B2World Admin

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# PDF Generation
PDF_TIMEOUT=30000
